---
import { Markdown } from "astro-remote";
import Utils from "../utils";
import edition from "../data/current.yaml";
const lang = Utils.getLang(Astro.url);

type translation = { fr: string; en: string };

const trad: { [key: string]: translation } = {
  desc: {
    fr: "La conférence Grenobloise sur les technologies et les innovations logicielles. Pendant 2 jours près de 700 personnes se réunissent pour partager et apprendre autour du développement logiciel.",
    en: "Grenoble's conference on software technologies and innovation. Over 2 days, nearly 700 people come together to share knowledge and learn about software development.",
  },
  conf: {
    fr: "Conférence",
    en: "Conference",
  },
  conf_desc: {
    fr: "2 journées de conférences",
    en: "2 days of conferences",
  },
  unconf: {
    fr: "Unconférence",
    en: "Unconference",
  },
  unconf_desc: {
    fr: "1 journée d’échanges sur la neige en montagne",
    en: "1 day of socialising in the snow in the mountains",
  },
  news: {
    fr: "Actualités",
    en: "News",
  },
  eta: {
    fr: "Prévu dans",
    en: "ETA",
  },
};
const ey = Utils.editionYear(edition.start_date);
const startFormat = Intl.DateTimeFormat(lang, {
  timeZone: "Europe/Paris",
  month: "long",
  day: "numeric",
});
const endFormat = Intl.DateTimeFormat(lang, {
  timeZone: "Europe/Paris",
  year: "numeric",
  month: "long",
  day: "numeric",
});
const startDate = Utils.resolveDate(edition.start_date, ey);
const start = startFormat.format(startDate);
const end = endFormat.format(Utils.resolveDate(edition.end_date, ey));
const year = ey;
---

<style>
  .full-bleed {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: repeat(4, 1fr);
    grid-template-areas:
      "haut-g haut-g haut-g . petit petit"
      "haut-g haut-g haut-g . . ."
      ". . . bas-d bas-d bas-d"
      ". . . bas-d bas-d bas-d";
    gap: 0;
    height: fit-content;
  }
  @media (max-width: 768px) {
    .full-bleed {
      grid-template-areas:
        "petit"
        "bas-d"
        "haut-g";
      grid-template-columns: 1fr;
      grid-template-rows: repeat(4, min-content);
    }
    .overlay-img {
      display: none; /* Souvent mieux de la cacher sur petit écran */
    }
  }
  .block {
    margin: clamp(0.5em, 3.125vw - 1em, 1em);
    padding: clamp(0.5em, 3.125vw - 1em, 1em);
    height: fit-content;
    width: fit-content;
    background: rgba(46, 40, 65, 0.7);
    border-radius: 12px;
    & > * {
      color: aliceblue;
    }

    & > h2,
    & > summary > h2 {
      color: #fff200;
      text-align: center;
    }

    & > h1 {
      color: #ff8a00;
      text-align: center;
      margin: 0;
    }
  }

  .news > summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5em;
  }
  .news > summary::-webkit-details-marker {
    display: none;
  }
  .news > summary > h2 {
    margin-block: 0;
    flex: 1;
  }
  .news .chevron {
    width: 1.25em;
    height: 1.25em;
    color: #fff200;
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  .news[open]:not([data-locked]) .chevron {
    transform: rotate(180deg);
  }

  .news[data-locked] > summary {
    cursor: default;
    pointer-events: none;
  }
  .news[data-locked] .chevron {
    display: none;
  }
  .news[data-locked] > summary > h2 {
    margin-block: revert;
  }
  dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5em;
  }
  .news dd > p {
    margin-block: 0;
  }
  .background {
    background: image-set(url("/img/fond/fond_2.avif") type("image/avif"))
      center/cover no-repeat;
    min-height: 550px;
    background-attachment: fixed;
  }
  .description {
    grid-area: haut-g;
    justify-self: center;
    align-self: center;
  }
  .news {
    grid-area: bas-d;
    width: auto;
    align-self: center;
  }
  .title {
    grid-area: petit;
    justify-self: center;
  }
  .bruno {
    grid-column: 1;
    grid-row: 4;
    max-width: 4em;
    justify-self: start;
    align-self: end;
    background: rgba(46, 40, 65, 0.7);
    border-radius: 12px;
  }

  .block :global(h3) {
    color: #00b9ff;
  }

  .block :global(p) {
    color: aliceblue;
  }

  .highlight {
    color: #8dc63f;
  }

  .countdown-box {
    width: clamp(300px, 40%, 500px);
    height: fit-content;
    padding: 2rem;
    background-color: #2e284199;
    font-size: clamp(16px, 3vw, 18px);

    & > * {
      color: white;
    }

    border-radius: 12px;
  }
  dl {
    & > dt:nth-child(3n) {
      color: #8dc63f;
    }
    & > dt:nth-child(3n + 1) {
      color: #ff8a00;
    }
    & > dt:nth-child(3n + 2) {
      color: #00b9ff;
    }
  }
</style>
<script>
  import { formatDuration } from "../lib/duration";

  const etaElem = document.getElementById("eta")!;
  const countdown = document.getElementById("countdown")!;
  const deadline = Number(countdown.dataset.date);
  const lang = (countdown.dataset.lang ?? "fr") as "fr" | "en";

  const updateEta = () => {
    const distance = (deadline - new Date().getTime()) / 1000;
    etaElem.innerText = formatDuration(distance, lang);
    return distance;
  };
  updateEta();
  const timer = setInterval(() => {
    if (updateEta() <= 0) clearInterval(timer);
  }, 1000);
  const now = new Date().getTime();
  for (const elem of document.querySelectorAll<HTMLElement>("[data-start]")) {
    const start = Number(elem.getAttribute("data-start"));
    const end = Number(elem.getAttribute("data-end"));
    if (now < start || end < now) {
      elem.style.display = "none";
    }
  }

  const newsDetails = document.getElementById(
    "news-details",
  ) as HTMLDetailsElement | null;
  if (newsDetails) {
    const desktop = window.matchMedia("(min-width: 769px)");
    const sync = () => {
      newsDetails.open = desktop.matches;
      newsDetails.toggleAttribute("data-locked", desktop.matches);
    };
    desktop.addEventListener("change", sync);
    sync();
  }
</script>

<div
  class="full-bleed background"
  id="countdown"
  data-date={Utils.resolveEpoch(edition.start_date, ey)}
  data-lang={lang}
>
  <div class="block description">
    <p>{trad.desc[lang]}</p>
    <dl>
      <dt>🎙️ {trad.conf[lang]}</dt>
      <dd>{trad.conf_desc[lang]}</dd>
      <dt>🏔️ {trad.unconf[lang]}</dt>
      <dd>{trad.unconf_desc[lang]}</dd>
    </dl>
  </div>
  <details class="block news" id="news-details">
    <summary>
      <h2>{trad.news[lang]}</h2>
      <!--?xml version="1.0" encoding="UTF-8"?-->
      <svg
        class="chevron"
        aria-hidden="true"
        focusable="false"
        width="24px"
        height="24px"
        stroke-width="1.5"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        color="#ffffff"
        ><path
          d="M12 8V16M12 16L15.5 12.5M12 16L8.5 12.5"
          stroke="#ffffff"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path><path
          d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"
          stroke="#ffffff"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path></svg
      >
    </summary>
    <dl>
      {
        edition.news.map((item: any) => (
          <Fragment>
            <dt
              data-start={Utils.resolveEpoch(item.start, ey)}
              data-end={Utils.resolveEpoch(item.end, ey)}
            >
              {item[`title_${lang}`]}
            </dt>
            <dd
              data-start={Utils.resolveEpoch(item.start, ey)}
              data-end={Utils.resolveEpoch(item.end, ey)}
            >
              <Markdown content={item[`description_${lang}`]} />
            </dd>
          </Fragment>
        ))
      }
    </dl>
  </details>
  <div class="block title">
    <h1>Snowcamp {year}</h1>
    <p style="margin: 0;">
      <span class="highlight">{start} - {end}</span>, Grenoble<br />
      {trad.eta[lang]}
      <span id="eta"></span>
    </p>
  </div>
  <img class="bruno" src="/img/fond/Logo Bruno Lavit blanc.png" />
</div>
