---
import Utils from "../utils";

type translation = { fr: string; en: string };
type language = keyof translation;

const lang = Utils.getLang(Astro.url) as language;
const changeLang = lang === "fr" ? "/en/" : "/";
const targetLang = lang === "en" ? "fr" : "en";

const trad: { [key: string]: translation } = {
  what: {
    fr: "C'est quoi ?",
    en: "What is this?",
  },
  organisation: {
    fr: "Organisation",
    en: "Organisation",
  },
  association: {
    fr: "Association",
    en: "Association",
  },
  past_editions: {
    fr: "Éditions précédentes",
    en: "Past Edition",
  },
  speaker: {
    fr: "Orateurs",
    en: "Speakers",
  },
  attendee: {
    fr: "Participants",
    en: "Attendee",
  },
  our_sponsors: {
    fr: "Nos sponsors",
    en: "Our sponsors",
  },
  become_sponsor: {
    fr: "Devenir sponsors",
    en: "Become sponsors",
  },
  sponsor_plan_title: {
    fr: "Plan des stands",
    en: "Plan of booths",
  },
  sponsor_meetgreet_title: {
    fr: "Meet & Greet",
    en: "Meet & Greet",
  },
  sponsor_guide_title: {
    fr: "Guide du sponsor",
    en: "Sponsor guide",
  },
  venue: {
    fr: "Venir",
    en: "Venue",
  },
  ticket: {
    fr: "Billetterie",
    en: "Tickets",
  },
  videos: {
    fr: "Vidéos",
    en: "Videos",
  },
  coc: {
    fr: "CDC",
    en: "COC",
  },
  program: {
    fr: "Programme",
    en: "Program",
  },
  conference: {
    fr: "Conférence",
    en: "Conference",
  },
  tremplin: {
    fr: "le Tremplin",
    en: "Tremplin",
  },
  editorialLine: {
    fr: "Ligne éditoriale",
    en: "Editorial line",
  },
  speakersGuide: {
    fr: "Guide de l'orateur",
    en: "Speakers guide",
  },
  venue_link: {
    fr: "/#venue",
    en: "/en/#venue",
  },
};
---

<style>
  nav {
    display: grid;
    grid-template-columns: 1fr min(100ch, 100%) 1fr;
    justify-items: stretch;
    & > .line {
      grid-column: 2;
    }
    & > :not(:first-child) {
      background-color: var(--main2);
    }
  }
  .line {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
  }
  .menu {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    column-gap: 1rem;
    justify-content: space-evenly;
    position: relative;
    & > li {
      width: 1fr;
      text-align: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
  }
  .margin {
    display: none;
    background-color: var(--main2);
    grid-row: 2;
    &.left {
      grid-column: 1;
    }
    &.left {
      grid-column: 3;
    }
    &.is-open {
      display: block;
    }
  }

  a {
    color: inherit;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    height: 100%;
  }
  ul {
    list-style-type: none;
    padding: 0;
    align-items: stretch;
    margin: 0;
  }
  li.center {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 3px;
  }

  button {
    background: none;
    border: none;
    color: inherit;
    font: inherit;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  button::after {
    content: "▼";
    font-size: 0.6em;
  }
  button:hover {
    color: var(--orange-on-main);
  }

  ul.line.menu {
    display: none;
  }
  ul.line.menu.is-open {
    display: flex;
  }

  a:hover {
    color: var(--orange-on-main);
  }
</style>

<nav aria-label="Navigation principale">
  <div class="line">
    <a href={Utils.url("", { lang })}>
      <img
        style="max-width: 170px; min-height: 1rem;"
        src={Utils.url("/img/alpes-snow-full-illustration.webp")}
        alt="Logo"
      />
    </a>
    <ul class="menu">
      <li>
        <button
          aria-expanded="false"
          aria-haspopup="true"
          aria-controls="menu-sponsors"
        >
          Sponsors
        </button>
      </li>
      <li>
        <button
          aria-expanded="false"
          aria-haspopup="true"
          aria-controls="menu-speaker"
        >
          {trad.speaker[lang]}
        </button>
      </li>
      <li>
        <button
          aria-expanded="false"
          aria-haspopup="true"
          aria-controls="menu-attendee"
        >
          {trad.attendee[lang]}
        </button>
      </li>
      <li>
        <button
          aria-expanded="false"
          aria-haspopup="true"
          aria-controls="menu-snowcamp"
        >
          Snowcamp
        </button>
      </li>
      <li>
        <a href={Utils.url(["alpexpo"], { lang })}>{trad.venue[lang]}</a>
      </li>
      <li class="center">
        <a href={changeLang}
          ><img
            style="max-height: 1em;"
            class="snc-flag"
            src=`/img/${targetLang}.svg`
            alt="Switch to French"
          /></a
        >
      </li>
    </ul>
  </div>
  <div class="margin left"></div>
  <ul class="line menu" id="menu-sponsors">
    <li>
      <a href={Utils.url([], { anchor: "#sponsors", lang })}
        >{trad.our_sponsors[lang]}</a
      >
    </li>
    <li>
      <a href={Utils.url(["sponsors"], { lang })}>{trad.become_sponsor[lang]}</a
      >
    </li>
    <li>
      <a href={Utils.url(["sponsors"], { anchor: "#plan", lang })}
        >{trad.sponsor_plan_title[lang]}</a
      >
    </li>
    <li>
      <a href={Utils.url(["sponsors"], { anchor: "#beers", lang })}
        >{trad.sponsor_meetgreet_title[lang]}</a
      >
    </li>
    <li>
      <a href={Utils.url(["sponsors_guide"], { lang })}
        >{trad.sponsor_guide_title[lang]}</a
      >
    </li>
  </ul>
  <ul class="line menu" id="menu-speaker">
    <li>
      <a href={Utils.url(["cfp"], { lang })}>{trad.conference[lang]}</a>
    </li>
    <li>
      <a href={Utils.url(["tremplin"], { lang })}>{trad.tremplin[lang]}</a>
    </li>
    <li>
      <a href={Utils.url(["editorial-line"], { lang })}
        >{trad.editorialLine[lang]}</a
      >
    </li>
    <li>
      <a href={Utils.url(["speakers-guide"], { lang })}
        >{trad.speakersGuide[lang]}</a
      >
    </li>
  </ul>
  <ul class="line menu" id="menu-attendee">
    <li><a href={Utils.url(["tickets"])}>{trad.ticket[lang]}</a></li>
  </ul>
  <ul class="line menu" id="menu-snowcamp">
    <li><a href={Utils.url(["snowcamp"], { lang })}>{trad.what[lang]}</a></li>
    <li>
      <a href={Utils.url(["organisation"], { lang })}
        >{trad.organisation[lang]}</a
      >
    </li>
    <li>
      <a href={Utils.url(["association"], { lang })}>{trad.association[lang]}</a
      >
    </li>
    <li>
      <a href={Utils.url(["previous-editions"], { lang })}
        >{trad.past_editions[lang]}</a
      >
    </li>
    <li>
      <a
        href="https://www.youtube.com/channel/UCvRA5NSOfGOPet90fdV7uuw/videos"
        target="_blank"
        rel="noopener noreferrer">{trad.videos[lang]}</a
      >
    </li>
    <li><a href={Utils.url(["coc"], { lang })}>{trad.coc[lang]}</a></li>
  </ul>
  <div class="margin right"></div>
</nav>

<script>
  const topLevel = document.querySelectorAll<HTMLButtonElement>(
    'button[aria-haspopup="true"]',
  );
  const margin = document.querySelectorAll<HTMLElement>(".margin");

  function closeAll(except: HTMLElement | null = null) {
    document.querySelectorAll("ul.line.menu").forEach((item) => {
      if (item !== except) {
        item.classList.remove("is-open");
        const btn = item.querySelector("button");
        if (btn) btn.setAttribute("aria-expanded", "false");
      }
    });
    if (except == null) {
      margin.forEach((elem) => {
        elem.classList.remove("is-open");
      });
    }
  }

  topLevel.forEach((btn) => {
    const subid = btn.getAttribute("aria-controls");
    if (!subid) return;
    const submenu = document.getElementById(subid);
    if (!submenu) return;

    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = submenu.classList.contains("is-open");
      closeAll();
      if (!isOpen) {
        submenu.classList.add("is-open");
        btn.setAttribute("aria-expanded", "true");
        margin.forEach((elem) => {
          elem.classList.add("is-open");
        });
      }
    });

    btn.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        closeAll();
        btn.focus();
      }
      if (e.key === "ArrowDown" && submenu.classList.contains("is-open")) {
        e.preventDefault();
        (submenu.querySelector("a") as HTMLElement | null)?.focus();
      }
    });

    submenu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("keydown", (e) => {
        if ((e as KeyboardEvent).key === "Escape") {
          closeAll();
          btn.focus();
        }
      });
    });
  });
</script>
