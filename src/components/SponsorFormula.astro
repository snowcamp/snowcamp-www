---
import { type SponsorType } from "./sponsor";
import Utils from "../utils";
import type { Language, Translation, LangFn } from "../lib/types";

interface Props {
  sponsor: SponsorType;
  active: boolean;
  previousSponsor?: SponsorType | null;
}
const { sponsor, active, previousSponsor = null } = Astro.props;
const lang = Utils.getLang(Astro.url) as Language;
const sponsorWord = sponsor.number > 1 ? "sponsors" : "sponsor";

const trad: {
  titles: Record<string, Translation>;
  limited: LangFn<[number, string]>;
  "item-conferences-count": LangFn<[number]>;
  "item-conferences-label": Translation;
  "item-logo-comms": Translation;
  "item-logo-venue": Translation;
  "item-logo-snowcamp": Translation;
  "item-kakemono": Translation;
  "item-booth": LangFn<[string]>;
  "item-booth-tickets": LangFn<[number]>;
  "item-badge-logo": Translation;
} = {
  titles: {
    chamois: { fr: "Chamois", en: "Chamois" },
    etoile: { fr: "Étoile", en: "Étoile" },
    flocon: { fr: "Flocon", en: "Flocon" },
  },
  limited: {
    fr: (n, s) => `Limité à ${n} ${s}`,
    en: (n, s) => `Limited to ${n} ${s}`,
  },
  "item-conferences-count": {
    fr: (n) => `${n} entrées`,
    en: (n) => `${n} tickets`,
  },
  "item-conferences-label": {
    fr: "conférences offertes",
    en: "to attend the sessions",
  },
  "item-logo-comms": {
    fr: "Logo dans toutes nos communications",
    en: "Your logo on all our communications",
  },
  "item-logo-venue": {
    fr: "Affichage de votre logo sur le lieu de la conférence",
    en: "Your logo visible on the location of the conference",
  },
  "item-logo-snowcamp": {
    fr: "Autorisation d'exploitation du logo SnowCamp",
    en: "Authorisation to use the SnowCamp logo",
  },
  "item-kakemono": {
    fr: "Un kakémono (max 1m x 2m50)",
    en: "1 kakémono (max 1m x 2m50)",
  },
  "item-booth": {
    fr: (area) => `Stand sponsor (${area})`,
    en: (area) => `Booth in the exhibition hall (${area})`,
  },
  "item-booth-tickets": {
    fr: (n) => `${n} entrées sur l'espace sponsor uniquement`,
    en: (n) => `${n} tickets for the sponsors space only`,
  },
  "item-badge-logo": {
    fr: "Votre logo sur le badge des participants.",
    en: "Your logo on the badge of each participant of the conference.",
  },
};

const show = {
  conferences: (sponsor?.places?.conferences ?? 0) > 0,
  kakemono: !!sponsor.kakemono,
  booth: !!sponsor.booth_area,
  boothTickets: (sponsor?.places?.booth ?? 0) > 0,
  badgeLogo: !!sponsor.badge_logo,
};

const isNew = {
  kakemono: show.kakemono && !previousSponsor?.kakemono,
  booth: show.booth && !previousSponsor?.booth_area,
  boothTickets:
    show.boothTickets && !((previousSponsor?.places?.booth ?? 0) > 0),
  badgeLogo: show.badgeLogo && !previousSponsor?.badge_logo,
};
---

<style>
  section {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    margin: 1rem;
    border-radius: 5px;
    background-color: var(--main);
    & > header > * {
      color: var(--background);
    }
    & > header > h4 {
      color: var(--background);
    }
  }
  section.active {
    background-color: var(--orange);
    & > header > * {
      color: var(--main);
    }
    & > header > h4 {
      color: var(--background);
    }
  }
  header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
  }
  ul {
    display: flex;
    flex-direction: column;
    align-items: center;
    background-color: var(--background);
    margin: 1ex;
    list-style-type: none;
    padding: 1ex 1rem;
    gap: 1ex;
  }
  li {
    text-align: center;
    &::before {
      content: "✔  ";
      color: var(--green);
    }
    &.hidden {
      display: none;
    }
  }
  .highlight {
    background: var(--green);
    padding: 4px 4px;
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
    color: var(--background);
  }
</style>

<section class={active ? "active" : ""}>
  <header>
    <h2>{trad.titles[sponsor.id]?.[lang] ?? sponsor.id}</h2>
    <h4>{sponsor.price}</h4>
    <p>{trad.limited[lang](sponsor.number, sponsorWord)}</p>
  </header>
  <ul>
    <li class={show.conferences ? undefined : "hidden"}>
      <span class="highlight"
        >{
          trad["item-conferences-count"][lang](sponsor.places.conferences!)
        }</span
      >
      {trad["item-conferences-label"][lang]}
    </li>
    <li>{trad["item-logo-comms"][lang]}</li>
    <li>{trad["item-logo-venue"][lang]}</li>
    <li>{trad["item-logo-snowcamp"][lang]}</li>
    <li class={show.kakemono ? undefined : "hidden"}>
      {
        isNew.kakemono ? (
          <b>{trad["item-kakemono"][lang]}</b>
        ) : (
          trad["item-kakemono"][lang]
        )
      }
    </li>
    <li class={show.booth ? undefined : "hidden"}>
      {
        isNew.booth ? (
          <b>{trad["item-booth"][lang](sponsor.booth_area!)}</b>
        ) : (
          trad["item-booth"][lang](sponsor.booth_area!)
        )
      }
    </li>
    <li class={show.boothTickets ? undefined : "hidden"}>
      {
        isNew.boothTickets ? (
          <b>{trad["item-booth-tickets"][lang](sponsor.places.booth!)}</b>
        ) : (
          trad["item-booth-tickets"][lang](sponsor.places.booth!)
        )
      }
    </li>
    <li class={show.badgeLogo ? undefined : "hidden"}>
      {
        isNew.badgeLogo ? (
          <b>{trad["item-badge-logo"][lang]}</b>
        ) : (
          trad["item-badge-logo"][lang]
        )
      }
    </li>
  </ul>
</section>
